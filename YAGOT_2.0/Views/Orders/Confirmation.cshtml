@model YAGOT_2._0.Models.Order

@{
    ViewData["Title"] = "تأكيد الطلب";
}

<div style="text-align: center; padding: 60px 0;">
    <h1 style="color: var(--primary-gold); font-size: 2.5rem; margin-bottom: 20px;">تم تأكيد طلبك بنجاح!</h1>
    <p style="font-size: 1.2rem; color: var(--gray-text); margin-bottom: 10px;">شكراً لثقتك في ياقوت.</p>
    <p style="font-size: 1.1rem;">رقم التتبع الخاص بك هو: <strong style="color: var(--primary-gold);">@Model.Trackingnumber</strong></p>
    
    <div style="max-width: 600px; margin: 40px auto; background-color: var(--dark-surface); padding: 30px; border-radius: 8px; border: 1px solid var(--border-color); text-align: right;">
        <h2>ملخص الطلب</h2>
        <ul style="list-style: none; padding: 0; margin-bottom: 20px;">
            @foreach(var item in Model.Orderitems)
            {
                <li style="display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid var(--border-color);">
                    <span>@item.Product?.Name &times; @item.Quantity</span>
                    <span>@((item.Quantity * item.Unitprice)+ "ر.س")</span>
                </li>
            }
        </ul>
        <div style="display: flex; justify-content: space-between; font-weight: bold; font-size: 1.2rem; color: var(--primary-gold);">
            <span>الإجمالي:</span>
            <span>@Model.Totalamount ر.س</span>
        </div>
    </div>

    <a asp-controller="Home" asp-action="Index" class="btn-outline">العودة للرئيسية</a>
</div>
