@model IEnumerable<YAGOT_2._0.Models.Product>

@{
    ViewData["Title"] = ViewBag.CategoryName != null ? $"منتجات: {ViewBag.CategoryName}" : "قائمة المنتجات";
    var categories = ViewBag.Categories as List<YAGOT_2._0.Models.Category>;
    int? currentCategoryId = ViewBag.CategoryId as int?;
}

<h1 style="border-bottom: 1px solid var(--border-color); padding-bottom: 20px; margin-bottom: 20px;">
    @if(ViewBag.CategoryName != null)
    {
        <span>منتجات: @ViewBag.CategoryName</span>
        <a asp-action="Index" style="color: var(--gray-text); font-size: 0.9rem; margin-right: 15px; text-decoration: none;">← عرض الكل</a>
    }
    else
    {
        <span>المجموعة الكاملة</span>
    }
</h1>

<!-- فلتر التصنيفات -->
@if(categories != null && categories.Any())
{
    <div style="display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 30px;">
        <a asp-action="Index"
           style="padding: 8px 18px; border-radius: 20px; text-decoration: none; font-size: 0.9rem; transition: all 0.3s; @(currentCategoryId == null ? "background-color: var(--primary-gold); color: var(--dark-bg);" : "background-color: var(--dark-surface); color: var(--light-text); border: 1px solid var(--border-color);")">
            الكل
        </a>
        @foreach(var cat in categories)
        {
            <a asp-action="Index" asp-route-categoryId="@cat.Id"
               style="padding: 8px 18px; border-radius: 20px; text-decoration: none; font-size: 0.9rem; transition: all 0.3s; @(currentCategoryId == cat.Id ? "background-color: var(--primary-gold); color: var(--dark-bg);" : "background-color: var(--dark-surface); color: var(--light-text); border: 1px solid var(--border-color);")">
                @cat.Name
            </a>
        }
    </div>
}

<div class="products-grid">
    @if(Model.Any())
    {
        @foreach(var item in Model)
        {
            <div class="product-card">
                <img src="@item.Imageurl" alt="@item.Name" onerror="this.onerror=null;this.src='/images/placeholder-product.svg';" style="width: 100%; height: 200px; object-fit: cover; border-radius: 4px; margin-bottom: 15px;" />

                <h3>@item.Name</h3>
                <p style="color: var(--gray-text); font-size: 0.9rem;">@item.Description</p>
                <div class="product-price">@item.Price.ToString("N0") ر.س</div>
                <a asp-action="Details" asp-route-id="@item.Id" class="btn-outline">عرض التفاصيل</a>
            </div>
        }
    }
    else
    {
        <p style="color: var(--gray-text);">لا توجد منتجات في هذا التصنيف.</p>
    }
</div>
