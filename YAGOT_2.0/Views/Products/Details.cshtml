@model YAGOT_2._0.Models.Product

@{
    ViewData["Title"] = $"{Model?.Name} | ياقوت للمجوهرات";
}

@if (Model != null)
{
    <div style="margin-top: 40px; display: grid; grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); gap: 60px;">
        <!-- Product Image -->
        <div class="glass-effect" style="height: 500px; display: flex; align-items: center; justify-content: center; overflow: hidden; padding: 20px;">
            <img src="@Model.Imageurl" alt="@Model.Name" onerror="this.onerror=null;this.src='/images/placeholder-product.svg';" 
                 style="max-width: 100%; max-height: 100%; object-fit: contain; border-radius: 12px; box-shadow: 0 20px 40px rgba(0,0,0,0.4);" />
        </div>

        <!-- Product Info -->
        <div style="display: flex; flex-direction: column; justify-content: center;">
            <nav style="margin-bottom: 20px; font-size: 0.9rem;">
                <a asp-controller="Home" asp-action="Index" style="color: var(--gray-text); text-decoration: none;">الرئيسية</a>
                <span style="color: var(--border-color); margin: 0 10px;">/</span>
                <span style="color: var(--primary-gold);">تفاصيل المنتج</span>
            </nav>

            <h1 style="font-size: 3rem; font-weight: 800; margin-bottom: 15px; color: #fff;">@Model.Name</h1>
            
            <div style="display: flex; align-items: center; gap: 20px; margin-bottom: 30px;">
                <div class="product-price" style="font-size: 2.2rem; margin: 0;">@Model.Price.ToString("N0") ر.س</div>
            </div>

            <div class="glass-effect" style="padding: 25px; margin-bottom: 30px; line-height: 1.8; color: var(--gray-text);">
                <p style="margin: 0;">@Model.Description</p>
                <div style="margin-top: 20px; padding-top: 20px; border-top: 1px solid var(--glass-border); display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                    <div>
                        <span style="color: var(--primary-gold);">الحالة:</span> 
                        @(Model.Stockquantity > 0 ? "متوفر في المخزون" : "غير متوفر حالياً")
                    </div>
                    <div>
                        <span style="color: var(--primary-gold);">الكمية المتاحة:</span> 
                        @Model.Stockquantity قطعة
                    </div>
                </div>
            </div>

            <form asp-controller="Cart" asp-action="Add" method="post" style="display: flex; gap: 20px; align-items: stretch;">
                <input type="hidden" name="productId" value="@Model.Id" />
                <div style="position: relative; width: 100px;">
                    <input type="number" name="quantity" value="1" min="1" max="@Model.Stockquantity" 
                           style="width: 70%; height: 70%; background: var(--glass-bg); border: 1px solid var(--glass-border); border-radius: 8px; color: white; padding: 10px; text-align: center; font-size: 1.1rem;" />
                </div>
                <button type="submit" class="btn-gold" style="flex: 1; padding: 15px; font-size: 1.2rem; border-radius: 8px;">
                    إضافة إلى حقيبة التسوق
                </button>
            </form>

            <div style="margin-top: 40px; display: flex; gap: 30px; color: var(--gray-text); font-size: 0.9rem;">
                <div style="display: flex; align-items: center; gap: 10px;">
                    <span style="color: var(--primary-gold); font-size: 1.2rem;">🛡️</span> ضمان أصالة المنتج
                </div>
                <div style="display: flex; align-items: center; gap: 10px;">
                    <span style="color: var(--primary-gold); font-size: 1.2rem;">🚚</span> شحن مؤمن بالكامل
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="glass-effect" style="text-align: center; padding: 100px; margin-top: 40px;">
        <h2 style="color: var(--gray-text);">نعتذر، لم يتم العثور على المنتج المطلوب.</h2>
        <a asp-action="Index" class="btn-gold" style="margin-top: 20px;">العودة للمنتجات</a>
    </div>
}
