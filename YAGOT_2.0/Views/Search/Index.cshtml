@model IEnumerable<YAGOT_2._0.Models.Product>
@using YAGOT_2._0.Models

@{
    ViewData["Title"] = "بحث";
    var categories = ViewBag.Categories as List<Category>;
    var query = ViewBag.Query as string;
    int? currentCategoryId = ViewBag.CategoryId as int?;
}

<h1 style="border-bottom: 1px solid var(--border-color); padding-bottom: 20px; margin-bottom: 20px;">بحث المنتجات</h1>

<form asp-controller="Search" asp-action="Index" method="get" class="search-page-form" style="margin-bottom: 28px; display: flex; flex-wrap: wrap; gap: 12px; align-items: flex-end;">
    <div style="flex: 1; min-width: 200px;">
        <label for="search-q" style="display: block; color: var(--gray-text); margin-bottom: 6px; font-size: 0.9rem;">كلمة البحث</label>
        <input id="search-q" type="search" name="q" value="@query" placeholder="اسم المنتج أو الوصف..." class="nav-search-input" style="width: 100%;" />
    </div>
    <div style="min-width: 180px;">
        <label for="search-cat" style="display: block; color: var(--gray-text); margin-bottom: 6px; font-size: 0.9rem;">التصنيف</label>
        <select id="search-cat" name="category" class="status-select" style="width: 100%; padding: 10px; border-radius: 8px;">
            <option value="">— الكل —</option>
            @if (categories != null)
            {
                foreach (var cat in categories)
                {
                    if (currentCategoryId == cat.Id)
                    {
                        <option value="@cat.Id" selected>@cat.Name</option>
                    }
                    else
                    {
                        <option value="@cat.Id">@cat.Name</option>
                    }
                }
            }
        </select>
    </div>
    <button type="submit" class="btn-gold" style="padding: 10px 22px;">بحث</button>
</form>

@if (string.IsNullOrWhiteSpace(query) && currentCategoryId is not > 0)
{
    <p style="color: var(--gray-text);">اختر تصنيفاً أو أدخل كلمة بحث (حرفان على الأقل للاقتراحات السريعة في الشريط العلوي).</p>
}
else if (!Model.Any())
{
    <p style="color: var(--gray-text);">لا توجد نتائج مطابقة.</p>
}

<div class="products-grid">
    @foreach (var item in Model)
    {
        <div class="product-card">
            <img src="@item.Imageurl" alt="@item.Name" onerror="this.onerror=null;this.src='/images/placeholder-product.svg';" style="width: 100%; height: 200px; object-fit: cover; border-radius: 4px; margin-bottom: 15px;" />
            <h3>@item.Name</h3>
            <p style="color: var(--gray-text); font-size: 0.9rem;">@item.Description</p>
            <div class="product-price">@item.Price.ToString("N0") ر.س</div>
            <a asp-controller="Products" asp-action="Details" asp-route-id="@item.Id" class="btn-outline">عرض التفاصيل</a>
        </div>
    }
</div>
