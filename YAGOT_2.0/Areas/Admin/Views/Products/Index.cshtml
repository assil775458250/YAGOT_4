@model YAGOT_2._0.Services.ViewModels

@{
    ViewData["Title"] = "إدارة المنتجات | لوحة التحكم";
}

<div class="glass-effect" style="padding: 30px; margin-bottom: 30px; display: flex; justify-content: space-between; align-items: center;">
    <h1 style="margin: 0; font-size: 1.8rem; color: var(--primary-gold);">إدارة المنتجات</h1>
    <div>
        <a asp-action="trash" class="btn-outline" style="border-radius: 8px;margin-left:20px">سله المحذوفات 🗑</a>
    <a asp-action="Create" class="btn-gold" style="border-radius: 8px;">+ إضافة منتج جديد</a>
    </div>

</div>

@if (TempData["Error"] != null)
{
    <div class="glass-effect" style="background: rgba(220, 53, 69, 0.1); color: #ff6b6b; padding: 15px; border-radius: 8px; margin-bottom: 20px; border-color: rgba(220, 53, 69, 0.2);">
        @TempData["Error"]
    </div>
}

<div style="display: grid; grid-template-columns: repeat(auto-fill,minmax(280px,1fr)); gap: 20px;">
    @foreach (var p in Model.Products)

    {

        if (!( p.Stockquantity == 0 && p.Imageurl == "/images/products/6389130_camera_interface_movie_picture_zoom_icon.png"))
        {
        var cat = Model.Categories.FirstOrDefault(c => c.Id == p.Categoryid);

        <div class="glass-effect" style="overflow: hidden; border-radius: 12px; border: 1px solid var(--glass-border); transition: 0.3s;">

            <!-- صورة المنتج -->
            <div style="height: 220px; overflow: hidden;">
                <img src="@p.Imageurl"
                     style="width: 100%; height: 100%; object-fit: cover;" />
            </div>

            <!-- محتوى الكارد -->
            <div style="padding: 18px;">

                <!-- الاسم -->
                <h3 style="margin-bottom: 10px; color: var(--light-text);">
                    @p.Name
                </h3>

                <!-- التصنيف -->
                <p style="color: var(--gray-text); margin-bottom: 10px;">
                    @(cat?.Name ?? "-")
                </p>

                <!-- السعر -->
                <div style="color: var(--primary-gold); font-size: 1.2rem; font-weight: bold; margin-bottom: 15px;">
                    @p.Price.ToString("N0") ر.س
                </div>

                <!-- المخزون -->
                <div style="margin-bottom: 18px;">
                    <span style="
                        background: @(p.Stockquantity < 5 ? "rgba(220, 53, 69, 0.2)" : "rgba(40, 167, 69, 0.2)");
                        color: @(p.Stockquantity < 5 ? "#ff6b6b" : "#4ade80");
                        padding: 5px 12px;
                        border-radius: 12px;
                        font-size: 0.85rem;">

                        @p.Stockquantity وحدة
                    </span>
                </div>

                <!-- الأزرار -->
                <div style="display: flex; gap: 10px;">

                    <a asp-action="Edit"
                       asp-route-id="@p.Id"
                       class="btn-outline"
                       style="flex:1; text-align:center; padding: 8px;">
                        تعديل
                    </a>

                    <form asp-action="Delete"
                          asp-route-id="@p.Id"
                          method="post"
                          style="flex:1;"
                          onsubmit="return confirm('هل أنت متأكد من حذف المنتج @p.Name ؟')">

                        <button type="submit"
                                style="
                                width:100%;
                                background: rgba(220, 53, 69, 0.1);
                                color: #ff6b6b;
                                border: 1px solid rgba(220, 53, 69, 0.2);
                                padding: 8px;
                                border-radius: 6px;
                                cursor: pointer;">

                            حذف
                        </button>
                    </form>

                </div>

            </div>
        </div>
        }
    }
</div>
