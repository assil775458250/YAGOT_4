    <!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script>
        (function () {
            try {
                var t = localStorage.getItem('theme');
                if (t === 'light') document.documentElement.setAttribute('data-theme', 'light');
                else document.documentElement.removeAttribute('data-theme');
            } catch (e) { }
        })();
    </script>
    <title>@ViewData["Title"] - لوحة إدارة ياقوت</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700&family=Tajawal:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .admin-wrapper {
            display: flex;
            min-height: 100vh;
        }
        .admin-sidebar {
            width: 260px;
            background-color: #0a0a0a;
            border-left: 1px solid var(--border-color);
            padding: 30px 0;
            position: fixed;
            top: 0;
            right: 0; /* ظاهرة افتراضياً على الشاشات الكبيرة */
            z-index: 1000;
            height: 100vh;
            overflow-y: auto;
        }

        html[data-theme="light"] .admin-sidebar,
        html[data-theme="light"] .mobile-admin-header {
            background-color: #fafafa;
        }
        .admin-sidebar .brand {
            color: var(--primary-gold);
            font-size: 1.5rem;
            font-weight: bold;
            padding: 0 25px 30px;
            border-bottom: 1px solid var(--border-color);
            margin-bottom: 20px;
            display: block;
            text-decoration: none;
        }
        .sidebar-nav {
            list-style: none;
            padding: 0;
            margin: 0;
        }
        .sidebar-nav li a {
            display: block;
            padding: 12px 25px;
            color: var(--gray-text);
            text-decoration: none;
            transition: all 0.3s;
            border-right: 3px solid transparent;
        }
        .sidebar-nav li a:hover,
        .sidebar-nav li a.active {
            color: var(--primary-gold);
            background-color: rgba(201, 161, 91, 0.08);
            border-right-color: var(--primary-gold);
        }
        .admin-content {
            margin-right: 260px; /* مساحة للقائمة الجانبية */
            flex: 1;
            padding: 30px 40px;
        }
        .stat-cards {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        .stat-card {
            background-color: var(--dark-surface);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 25px;
            text-align: center;
            transition: border-color 0.3s;
        }
        .stat-card:hover {
            border-color: var(--primary-gold);
        }
        .stat-card .number {
            font-size: 2.5rem;
            font-weight: bold;
            color: var(--primary-gold);
        }
        .stat-card .label {
            color: var(--gray-text);
            margin-top: 5px;
        }
        .admin-table {
            width: 100%;
            border-collapse: collapse;
            background-color: var(--dark-surface);
            border-radius: 8px;
            overflow: hidden;
        }
        .admin-table th {
            background-color: rgba(201, 161, 91, 0.1);
            color: var(--primary-gold);
            padding: 15px;
            text-align: right;
            font-weight: bold;
        }
        .admin-table td {
            padding: 12px 15px;
            border-bottom: 1px solid var(--border-color);
            color: var(--light-text);
        }
        .admin-table tr:hover td {
            background-color: rgba(255,255,255,0.02);
        }
        .badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 12px;
            font-size: 0.85rem;
        }
        .badge-pending { background-color: #443a1a; color: #f0c040; }
        .badge-processed { background-color: #2a3048; color: #9ab7ff; }
        .badge-shipped { background-color: #1a3344; color: #40a0f0; }
        .badge-delivered { background-color: #1a4420; color: #40f060; }
        .badge-cancelled { background-color: #441a1a; color: #f04040; }
        .badge-refunded { background-color: #3a2a44; color: #d4a5ff; }
        .btn-sm {
            padding: 6px 14px;
            font-size: 0.85rem;
            border-radius: 4px;
            cursor: pointer;
            border: none;
        }
        .btn-danger {
            background-color: #441a1a;
            color: #f04040;
            border: 1px solid #662020;
        }
        .btn-danger:hover { background-color: #662020; }

        /* التصميم المتجاوب (Responsive Design) */
        .mobile-admin-header {
            display: none; /* مخفي على الشاشات الكبيرة */
            background-color: #0a0a0a;
            border-bottom: 1px solid var(--border-color);
            padding: 15px 20px;
            align-items: center;
        }
        .admin-menu-toggle {
            background: none;
            border: none;
            color: var(--primary-gold);
            font-size: 1.8rem;
            cursor: pointer;
            margin-left: 15px; /* RTL */
        }
        .mobile-admin-header .brand {
            color: var(--primary-gold);
            font-size: 1.5rem;
            font-weight: bold;
            text-decoration: none;
        }

        @@media (max-width: 700px) {
            .mobile-admin-header {
                display: flex;
            }
            .admin-sidebar {
                right: -260px; /* إخفاء القائمة في الجوال */
                transition: right 0.3s ease-in-out;
            }
            .admin-sidebar.show {
                right: 0;
                box-shadow: -5px 0 15px rgba(0,0,0,0.5);
            }
            .admin-sidebar .brand {
                display: none; /* إخفاء الشعار لأن الشريط العلوي موجود */
            }
            .admin-content {
                margin-right: 0; /* إلغاء الإزاحة في الجوال */
                padding: 15px;
            }
            .stat-cards {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <!-- الشريط العلوي للجوال -->
    <header class="mobile-admin-header">
        <button type="button" class="admin-menu-toggle" aria-label="فتح القائمة" onclick="toggleAdminNav()">☰</button>
        <a class="brand" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">⬡ ياقوت - الإدارة</a>
        <button type="button" id="theme-toggle" class="theme-toggle" style="margin-right: auto;" aria-label="تبديل المظهر" title="المظهر">☽</button>
    </header>

    <div class="admin-wrapper">
        <aside class="admin-sidebar" id="adminSidebar">
            <a class="brand" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">⬡ ياقوت - الإدارة</a>
            <div style="padding: 0 25px 16px; display: flex; justify-content: flex-end;">
                <button type="button" id="theme-toggle-desktop" class="theme-toggle" aria-label="تبديل المظهر" title="المظهر">☽</button>
            </div>
            <ul class="sidebar-nav">
                <li class="FontSizeForm"><a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">📊 لوحة التحكم</a></li>
                <li class="FontSizeForm"><a asp-area="Admin" asp-controller="Products" asp-action="Index">📦 المنتجات</a></li>
                <li class="FontSizeForm"><a asp-area="Admin" asp-controller="Categories" asp-action="Index">🏷️ التصنيفات</a></li>
                <li class="FontSizeForm"><a asp-area="Admin" asp-controller="Orders" asp-action="Index">🧾 الطلبات</a></li>
                <li class="FontSizeForm"><a asp-area="Admin" asp-controller="Users" asp-action="Index">👥 المستخدمين</a></li>
                <li class="FontSizeForm"><a asp-area="" asp-controller="Home" asp-action="Index">🏠 العودة للمتجر</a></li>
            </ul>
        </aside>
        <main class="admin-content">
            @RenderBody()
        </main>
    </div>

    <script>
        function toggleAdminNav() {
            var sidebar = document.getElementById('adminSidebar');
            if (sidebar) {
                sidebar.classList.toggle('show');
            }
        }

        // استخدام Event Delegation مع تأخير بسيط لتأكيد الإغلاق بصرياً قبل الانتقال للصفحة
        document.addEventListener('click', function(e) {
            var sidebar = document.getElementById('adminSidebar');
            if (!sidebar) return;

            // إذا تم الضغط على رابط داخل القائمة
            var link = e.target.closest('.admin-sidebar a');
            if (link) {
                e.preventDefault(); // إيقاف الانتقال الفوري
                sidebar.classList.remove('show'); // إخفاء القائمة
                
                // الانتقال للصفحة بعد 200 ملي ثانية لكي يرى المستخدم أن القائمة اختفت
                setTimeout(function() {
                    window.location.href = link.href;
                }, 200);
                return;
            }
            
            // إغلاق القائمة عند الضغط خارجها
            if (sidebar.classList.contains('show') && 
                !e.target.closest('.admin-sidebar') && 
                !e.target.closest('.mobile-admin-header')) {
                sidebar.classList.remove('show');
            }
        });
    </script>
    <script src="~/js/theme.js" asp-append-version="true"></script>
    <script>
        (function () {
            function bind(btn) {
                if (!btn) return;
                btn.addEventListener('click', function () {
                    if (window.yagotToggleTheme) yagotToggleTheme();
                    sync();
                });
            }
            function sync() {
                document.querySelectorAll('#theme-toggle, #theme-toggle-desktop').forEach(function (btn) {
                    if (!btn) return;
                    var light = document.documentElement.getAttribute('data-theme') === 'light';
                    btn.setAttribute('aria-pressed', light ? 'true' : 'false');
                    btn.textContent = light ? '☀' : '☽';
                });
            }
            bind(document.getElementById('theme-toggle'));
            bind(document.getElementById('theme-toggle-desktop'));
            sync();
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
